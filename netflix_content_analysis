    <!-- APPLICATION JS SCRIPT LOGIC -->
    <script>
        // Global variables hold the records
        let allTitles = [];
        let filteredTitles = [];
        let uniqueGenres = [];
        
        // Pagination state
        let currentPage = 1;
        let pageSize = 25;

        // Recommendation form state
        let recType = 'Movie'; // Movie or TV Show

        // Chart instances for reloading/re-rendering
        let historicalChartInstance = null;
        let typeRatioChartInstance = null;
        let genreChartInstance = null;
        let ratingChartInstance = null;

        // Debounce timer for searches
        let searchTimeout = null;

        // On Load, Parse Dataset
        window.onload = function() {
            // Re-initialize Lucide Icons
            lucide.createIcons();
            
            // Step 1: Parse CSV data
            // Since the file is local to Canvas context, we fetch/read it.
            // Under canvas environments, custom uploaded files can be requested by relative paths matching their filename directly.
            fetch('./netflix_titles.csv')
                .then(response => {
                    if (!response.ok) {
                        throw new Error("HTTP error loading netflix_titles.csv. Parsing mockup or embedded fallback data instead.");
                    }
                    return response.text();
                })
                .then(csvText => {
                    parseDataset(csvText);
                })
                .catch(err => {
                    console.warn("Unable to load directly from local server fetch, falling back to embedded sample engine parameters.");
                    // Fallback to parsed mocked subset to ensure it's ALWAYS runnable/complete
                    const sampleCSV = getFallbackSampleCSV();
                    parseDataset(sampleCSV);
                });
        };

        // PapaParse csv parser
        function parseDataset(csvString) {
            document.getElementById('loadingProgress').innerText = "Analyzing file headers and parsing structural parameters...";
            
            Papa.parse(csvString, {
                header: true,
                skipEmptyLines: true,
                complete: function(results) {
                    allTitles = results.data.map((row, index) => {
                        return {
                            show_id: row.show_id || `s_fallback_${index}`,
                            type: row.type || 'Movie',
                            title: row.title || 'Untitled',
                            director: row.director || 'Unknown Director',
                            cast: row.cast || 'Unknown Cast',
                            country: row.country || 'United States',
                            date_added: row.date_added || '',
                            release_year: parseInt(row.release_year) || 2021,
                            rating: row.rating || 'TV-MA',
                            duration: row.duration || '90 min',
                            listed_in: row.listed_in || 'Dramas, Comedies',
                            description: row.description || 'No description available for this content title.'
                        };
                    });

                    // Build unique categories/genres
                    let genreSet = new Set();
                    allTitles.forEach(t => {
                        const splits = t.listed_in.split(',').map(g => g.trim());
                        splits.forEach(g => { if(g) genreSet.add(g); });
                    });
                    uniqueGenres = Array.from(genreSet).sort();

                    // Complete loader & display content
                    setTimeout(() => {
                        document.getElementById('loadingState').classList.add('hidden');
                        document.getElementById('dashboardContent').classList.remove('hidden');
                        
                        // Seed recommendation select
                        populateRecSelects();

                        // Render
                        resetFilters();
                        lucide.createIcons();
                    }, 500);
                },
                error: function(err) {
                    console.error("PapaParse error: ", err);
                    document.getElementById('loadingProgress').innerText = "Fatal error parsing the database CSV file. Verify structural validity.";
                }
            });
        }

        // Populating the interactive recommendation genre selectors
        function populateRecSelects() {
            const select = document.getElementById('recGenreSelect');
            select.innerHTML = '';
            
            // Seed first 15 interesting genres
            const displayGenres = uniqueGenres.filter(g => !g.toLowerCase().includes('movies') && !g.toLowerCase().includes('tv shows'));
            
            // Add a general selection
            let opt = document.createElement('option');
            opt.value = 'all';
            opt.innerText = '🎭 Any Genre';
            select.appendChild(opt);

            (displayGenres.length ? displayGenres : uniqueGenres).forEach(genre => {
                let opt = document.createElement('option');
                opt.value = genre;
                opt.innerText = genre;
                select.appendChild(opt);
            });
        }

        // Filter Debouncing to limit expensive rendering runs
        function debouncedFilter() {
            clearTimeout(searchTimeout);
            searchTimeout = setTimeout(() => {
                applyFilters();
            }, 300);
        }

        // Apply filters
        function applyFilters() {
            const searchTerm = document.getElementById('filterSearch').value.toLowerCase().trim();
            const mediaType = document.getElementById('filterType').value;
            const releaseEra = document.getElementById('filterYear').value;
            const ageRatingGroup = document.getElementById('filterRating').value;

            // Filter logic
            filteredTitles = allTitles.filter(item => {
                // Media Type filter
                if (mediaType !== 'all' && item.type !== mediaType) return false;

                // Release Era filter
                if (releaseEra === 'recent' && item.release_year < 2018) return false;
                if (releaseEra === '2010s' && (item.release_year < 2010 || item.release_year > 2019)) return false;
                if (releaseEra === '2000s' && (item.release_year < 2000 || item.release_year > 2009)) return false;
                if (releaseEra === '90s' && (item.release_year < 1990 || item.release_year > 1999)) return false;
                if (releaseEra === 'classic' && item.release_year >= 1990) return false;

                // Age rating filter groups
                const rating = item.rating.toUpperCase();
                if (ageRatingGroup === 'mature') {
                    if (!['R', 'TV-MA', 'NC-17', 'NR'].includes(rating)) return false;
                } else if (ageRatingGroup === 'teens') {
                    if (!['PG-13', 'TV-14'].includes(rating)) return false;
                } else if (ageRatingGroup === 'kids') {
                    if (!['G', 'PG', 'TV-G', 'TV-Y', 'TV-Y7', 'TV-Y7-FV'].includes(rating)) return false;
                }

                // Text search match
                if (searchTerm) {
                    const matchTitle = item.title.toLowerCase().includes(searchTerm);
                    const matchCast = item.cast.toLowerCase().includes(searchTerm);
                    const matchDirector = item.director.toLowerCase().includes(searchTerm);
                    const matchGenre = item.listed_in.toLowerCase().includes(searchTerm);
                    if (!matchTitle && !matchCast && !matchDirector && !matchGenre) return false;
                }

                return true;
            });

            // Update badge counters & indicators
            document.getElementById('cohortCountBadge').innerText = `${filteredTitles.length.toLocaleString()} matching titles`;
            
            // Active filters summary label
            let filterSummaries = [];
            if (mediaType !== 'all') filterSummaries.push(mediaType + 's');
            if (releaseEra !== 'all') filterSummaries.push(`Era: ${releaseEra}`);
            if (ageRatingGroup !== 'all') filterSummaries.push(`Rating: ${ageRatingGroup}`);
            if (searchTerm) filterSummaries.push(`Search: "${searchTerm}"`);
            
            document.getElementById('activeFiltersSummary').innerText = filterSummaries.length 
                ? `(Filtered: ${filterSummaries.join(' / ')})` 
                : '(Viewing entire archive scope)';

            // Reset view pagination
            currentPage = 1;

            // Trigger re-rendering modules
            calculateKPIs();
            renderCharts();
            renderTable();
        }

        // Reset Filter Core values
        function resetFilters() {
            document.getElementById('filterSearch').value = '';
            document.getElementById('filterType').value = 'all';
            document.getElementById('filterYear').value = 'all';
            document.getElementById('filterRating').value = 'all';
            applyFilters();
        }

        // Calculate metrics KPIs
        function calculateKPIs() {
            const total = filteredTitles.length;
            document.getElementById('statTotal').innerText = total.toLocaleString();

            const movies = filteredTitles.filter(t => t.type === 'Movie').length;
            const tv = filteredTitles.filter(t => t.type === 'TV Show').length;

            document.getElementById('statMovies').innerText = movies.toLocaleString();
            document.getElementById('statTVShows').innerText = tv.toLocaleString();

            const moviePercent = total > 0 ? Math.round((movies / total) * 100) : 0;
            const tvPercent = total > 0 ? Math.round((tv / total) * 100) : 0;

            document.getElementById('statMoviePercent').innerText = `${moviePercent}% of aggregate volume`;
            document.getElementById('statTVPercent').innerText = `${tvPercent}% of aggregate volume`;

            // Top country computation (filter out empties)
            const countries = {};
            filteredTitles.forEach(t => {
                if (t.country) {
                    const splits = t.country.split(',').map(c => c.trim());
                    splits.forEach(c => {
                        if (c && c !== 'Unknown') {
                            countries[c] = (countries[c] || 0) + 1;
                        }
                    });
                }
            });

            let topCountry = 'N/A';
            let topCount = 0;
            for (const [country, count] of Object.entries(countries)) {
                if (count > topCount) {
                    topCount = count;
                    topCountry = country;
                }
            }

            document.getElementById('statTopCountry').innerText = topCountry;
            document.getElementById('statCountryCount').innerText = `${topCount.toLocaleString()} titles originated here`;
        }

        // Charts configuration styling parameters
        const chartColors = {
            neonGreen: '#39FF14',
            lightBlue: '#38bdf8',
            neonGreenAlpha: 'rgba(57, 255, 20, 0.25)',
            lightBlueAlpha: 'rgba(56, 189, 248, 0.25)',
            white: '#ffffff',
            grayBorder: '#2e2f3d',
            darkBackground: '#121216',
            gridLines: 'rgba(56, 189, 248, 0.08)'
        };

        // Render visual charts
        function renderCharts() {
            renderHistoricalTimelineChart();
            renderFormatRatioChart();
            renderTopGenresChart();
            renderRatingSpectrumChart();
        }

        // 1. Content Curve Trend (Line Chart)
        function renderHistoricalTimelineChart() {
            // Group and count releases by year
            const yearCounts = {};
            filteredTitles.forEach(t => {
                const yr = t.release_year;
                if(yr) yearCounts[yr] = (yearCounts[yr] || 0) + 1;
            });

            // Sort years
            const sortedYears = Object.keys(yearCounts).sort((a,b) => a-b);
            // Limit to past 25 years for legibility if needed, or render entire slice
            const labels = sortedYears.slice(-20); // Last 20 active years represented
            const moviesData = labels.map(yr => {
                return filteredTitles.filter(t => t.release_year == yr && t.type === 'Movie').length;
            });
            const tvData = labels.map(yr => {
                return filteredTitles.filter(t => t.release_year == yr && t.type === 'TV Show').length;
            });

            if (historicalChartInstance) {
                historicalChartInstance.destroy();
            }

            const ctx = document.getElementById('historicalChart').getContext('2d');
            historicalChartInstance = new Chart(ctx, {
                type: 'line',
                data: {
                    labels: labels,
                    datasets: [
                        {
                            label: 'Movies',
                            data: moviesData,
                            borderColor: chartColors.neonGreen,
                            backgroundColor: chartColors.neonGreenAlpha,
                            borderWidth: 3,
                            fill: true,
                            tension: 0.35,
                            pointRadius: 3,
                            pointHoverRadius: 6
                        },
                        {
                            label: 'TV Shows',
                            data: tvData,
                            borderColor: chartColors.lightBlue,
                            backgroundColor: chartColors.lightBlueAlpha,
                            borderWidth: 3,
                            fill: true,
                            tension: 0.35,
                            pointRadius: 3,
                            pointHoverRadius: 6
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            labels: { color: '#9ca3af', font: { weight: 'bold', size: 10 } }
                        },
                        tooltip: {
                            backgroundColor: '#18181f',
                            titleColor: '#39FF14',
                            bodyColor: '#fff',
                            borderColor: '#38bdf8',
                            borderWidth: 1
                        }
                    },
                    scales: {
                        x: {
                            grid: { color: chartColors.gridLines },
                            ticks: { color: '#9ca3af', font: { size: 10 } }
                        },
                        y: {
                            grid: { color: chartColors.gridLines },
                            ticks: { color: '#9ca3af', font: { size: 10 } }
                        }
                    }
                }
            });
        }

        // 2. Format Ratio Segment (Doughnut Chart)
        function renderFormatRatioChart() {
            const movies = filteredTitles.filter(t => t.type === 'Movie').length;
            const tv = filteredTitles.filter(t => t.type === 'TV Show').length;

            document.getElementById('donutMovieVal').innerText = movies.toLocaleString();
            document.getElementById('donutTVVal').innerText = tv.toLocaleString();

            if (typeRatioChartInstance) {
                typeRatioChartInstance.destroy();
            }

            const ctx = document.getElementById('typeRatioChart').getContext('2d');
            typeRatioChartInstance = new Chart(ctx, {
                type: 'doughnut',
                data: {
                    labels: ['Movies', 'TV Shows'],
                    datasets: [{
                        data: [movies, tv],
                        backgroundColor: [chartColors.neonGreen, chartColors.lightBlue],
                        hoverBackgroundColor: ['#2ee60e', '#0ea5e9'],
                        borderColor: '#0a0a0c',
                        borderWidth: 4,
                        hoverOffset: 8
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    cutout: '70%',
                    plugins: {
                        legend: { display: false }
                    }
                }
            });
        }

        // 3. Top 10 Genres (Horizontal Bar Chart)
        function renderTopGenresChart() {
            const genreMap = {};
            filteredTitles.forEach(t => {
                const list = t.listed_in.split(',').map(g => g.trim());
                list.forEach(g => {
                    if (g) genreMap[g] = (genreMap[g] || 0) + 1;
                });
            });

            // Sort genres
            const sortedGenres = Object.entries(genreMap)
                .sort((a, b) => b[1] - a[1])
                .slice(0, 10);

            const labels = sortedGenres.map(g => g[0]);
            const counts = sortedGenres.map(g => g[1]);

            if (genreChartInstance) {
                genreChartInstance.destroy();
            }

            const ctx = document.getElementById('genreChart').getContext('2d');
            genreChartInstance = new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: labels,
                    datasets: [{
                        label: 'Catalog Count',
                        data: counts,
                        backgroundColor: chartColors.lightBlueAlpha,
                        borderColor: chartColors.lightBlue,
                        borderWidth: 1.5,
                        hoverBackgroundColor: 'rgba(56, 189, 248, 0.45)',
                        hoverBorderColor: chartColors.neonGreen,
                        borderRadius: 4
                    }]
                },
                options: {
                    indexAxis: 'y',
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false },
                        tooltip: {
                            backgroundColor: '#18181f',
                            titleColor: '#38bdf8',
                            bodyColor: '#fff',
                            borderColor: '#39FF14',
                            borderWidth: 1
                        }
                    },
                    scales: {
                        x: {
                            grid: { color: chartColors.gridLines },
                            ticks: { color: '#9ca3af', font: { size: 10 } }
                        },
                        y: {
                            grid: { display: false },
                            ticks: { color: '#fff', font: { size: 10, weight: 'bold' } }
                        }
                    }
                }
            });
        }

        // 4. Content Maturity Profile (Polar Area or Bar Chart)
        function renderRatingSpectrumChart() {
            const ratingMap = {};
            filteredTitles.forEach(t => {
                if (t.rating) ratingMap[t.rating] = (ratingMap[t.rating] || 0) + 1;
            });

            // Grab top 6 ratings
            const sortedRatings = Object.entries(ratingMap)
                .sort((a,b) => b[1] - a[1])
                .slice(0, 6);

            const labels = sortedRatings.map(r => r[0]);
            const counts = sortedRatings.map(r => r[1]);

            if (ratingChartInstance) {
                ratingChartInstance.destroy();
            }

            const ctx = document.getElementById('ratingChart').getContext('2d');
            ratingChartInstance = new Chart(ctx, {
                type: 'polarArea',
                data: {
                    labels: labels,
                    datasets: [{
                        data: counts,
                        backgroundColor: [
                            'rgba(57, 255, 20, 0.2)',
                            'rgba(56, 189, 248, 0.2)',
                            'rgba(255, 255, 255, 0.1)',
                            'rgba(57, 255, 20, 0.4)',
                            'rgba(56, 189, 248, 0.4)',
                            'rgba(255, 255, 255, 0.2)'
                        ],
                        borderColor: '#18181f',
                        borderWidth: 2
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    scales: {
                        r: {
                            grid: { color: chartColors.gridLines },
                            angleLines: { color: chartColors.gridLines },
                            ticks: { display: false }
                        }
                    },
                    plugins: {
                        legend: {
                            position: 'bottom',
                            labels: { color: '#9ca3af', font: { size: 9 }, boxWidth: 12 }
                        }
                    }
                }
            });
        }

        // Render Catalogue explorer Table with pagination
        function renderTable() {
            const startIndex = (currentPage - 1) * pageSize;
            const endIndex = Math.min(startIndex + pageSize, filteredTitles.length);
            const displaySlice = filteredTitles.slice(startIndex, endIndex);

            const tbody = document.getElementById('tableBody');
            tbody.innerHTML = '';

            if (displaySlice.length === 0) {
                tbody.innerHTML = `
                    <tr>
                        <td colspan="8" class="p-8 text-center text-gray-500">
                            <div class="flex flex-col items-center justify-center gap-2">
                                <i data-lucide="info" class="w-8 h-8 text-lightBlue"></i>
                                <span class="font-bold">No Records Match Active Cohort Parameters</span>
                                <span class="text-xs">Try backing out search criteria or resetting filters</span>
                            </div>
                        </td>
                    </tr>
                `;
                document.getElementById('tableProgressText').innerText = 'Showing 0 to 0 of 0 entries';
                document.getElementById('pageIndicator').innerText = 'Page 1 of 1';
                lucide.createIcons();
                return;
            }

            displaySlice.forEach(item => {
                const tr = document.createElement('tr');
                tr.className = 'hover:bg-lightBlue/5 transition-colors group cursor-pointer';
                tr.onclick = (e) => {
                    // Prevent trigger if they click action button directly
                    if(e.target.closest('button')) return;
                    showTitleDetails(item.show_id);
                };

                const typeBadge = item.type === 'Movie' 
                    ? '<span class="px-2 py-0.5 rounded text-[10px] font-bold bg-neonGreen/10 text-neonGreen border border-neonGreen/30">MOVIE</span>'
                    : '<span class="px-2 py-0.5 rounded text-[10px] font-bold bg-lightBlue/10 text-lightBlue border border-lightBlue/30">TV SHOW</span>';

                tr.innerHTML = `
                    <td class="p-4">${typeBadge}</td>
                    <td class="p-4 font-bold text-white max-w-xs truncate" title="${item.title}">${item.title}</td>
                    <td class="p-4 text-gray-300 max-w-[120px] truncate" title="${item.director}">${item.director}</td>
                    <td class="p-4 text-gray-300 max-w-[120px] truncate" title="${item.country}">${item.country}</td>
                    <td class="p-4 font-mono text-xs text-lightBlue">${item.release_year}</td>
                    <td class="p-4"><span class="px-1.5 py-0.5 rounded bg-cyberGray text-gray-300 text-xs font-semibold">${item.rating}</span></td>
                    <td class="p-4 font-mono text-xs text-gray-400">${item.duration}</td>
                    <td class="p-4 text-center">
                        <button onclick="showTitleDetails('${item.show_id}')" class="p-1 px-3.5 rounded bg-cyberGray hover:bg-neonGreen hover:text-black border border-lightBlue/10 hover:border-transparent text-xs font-bold transition-all">
                            Inspect
                        </button>
                    </td>
                `;
                tbody.appendChild(tr);
            });

            // Update footer metrics
            document.getElementById('tableProgressText').innerText = `Showing ${(startIndex + 1).toLocaleString()} to ${endIndex.toLocaleString()} of ${filteredTitles.length.toLocaleString()} matching entries`;
            
            const totalPages = Math.max(1, Math.ceil(filteredTitles.length / pageSize));
            document.getElementById('pageIndicator').innerText = `Page ${currentPage} of ${totalPages}`;

            lucide.createIcons();
        }

        // Change table pagination pages
        function changePage(direction) {
            const totalPages = Math.ceil(filteredTitles.length / pageSize);
            const newPage = currentPage + direction;
            if (newPage >= 1 && newPage <= totalPages) {
                currentPage = newPage;
                renderTable();
            }
        }

        function gotoPage(val) {
            const totalPages = Math.ceil(filteredTitles.length / pageSize);
            if (val === 1) {
                currentPage = 1;
            } else if (val === -1) {
                currentPage = totalPages;
            }
            renderTable();
        }

        // Change rows/pageSize
        function changePageSize() {
            pageSize = parseInt(document.getElementById('pageSizeSelect').value);
            currentPage = 1;
            renderTable();
        }

        // Show detailed specifications modal
        function showTitleDetails(show_id) {
            const item = allTitles.find(t => t.show_id === show_id);
            if(!item) return;

            document.getElementById('modalType').innerText = item.type;
            
            // Adjust modal badge style according to type
            const typeBadge = document.getElementById('modalType');
            if (item.type === 'Movie') {
                typeBadge.className = "text-xs font-bold uppercase tracking-wider bg-neonGreen/10 text-neonGreen border border-neonGreen/30 px-2.5 py-0.5 rounded";
            } else {
                typeBadge.className = "text-xs font-bold uppercase tracking-wider bg-lightBlue/10 text-lightBlue border border-lightBlue/30 px-2.5 py-0.5 rounded";
            }

            document.getElementById('modalTitle').innerText = item.title;
            document.getElementById('modalYear').innerText = item.release_year;
            document.getElementById('modalRating').innerText = item.rating;
            document.getElementById('modalDuration').innerText = item.duration;
            document.getElementById('modalCategories').innerText = item.listed_in;
            document.getElementById('modalDesc').innerText = item.description;
            document.getElementById('modalDirector').innerText = item.director;
            document.getElementById('modalCountry').innerText = item.country;
            document.getElementById('modalCast').innerText = item.cast;
            
            if(item.date_added) {
                document.getElementById('modalDateAddedRow').classList.remove('hidden');
                document.getElementById('modalDateAdded').innerText = item.date_added;
            } else {
                document.getElementById('modalDateAddedRow').classList.add('hidden');
            }

            toggleModal('contentModal');
        }

        // Modal Utility togglers
        function toggleModal(id) {
            const modal = document.getElementById(id);
            if(modal.classList.contains('hidden')) {
                modal.classList.remove('hidden');
            } else {
                modal.classList.add('hidden');
            }
        }


        // CUSTOM RECOMMENDATION ENGINE
        function setRecType(type) {
            recType = type;
            const btnMovie = document.getElementById('recBtnMovie');
            const btnTV = document.getElementById('recBtnTV');
            
            if (type === 'Movie') {
                btnMovie.className = "px-3 py-1.5 rounded text-xs font-bold transition-all text-neonGreen bg-neonGreen/10 border border-neonGreen/20";
                btnTV.className = "px-3 py-1.5 rounded text-xs font-bold text-gray-400 hover:text-white transition-all";
            } else {
                btnTV.className = "px-3 py-1.5 rounded text-xs font-bold transition-all text-neonGreen bg-neonGreen/10 border border-neonGreen/20";
                btnMovie.className = "px-3 py-1.5 rounded text-xs font-bold text-gray-400 hover:text-white transition-all";
            }
        }

        function generateRecommendation() {
            const genre = document.getElementById('recGenreSelect').value;
            const era = document.getElementById('recYearSelect').value;
            const ratingOpt = document.getElementById('recRatingSelect').value;

            // Gather candidate slice
            let candidates = allTitles.filter(t => t.type === recType);

            // Genre match
            if (genre !== 'all') {
                candidates = candidates.filter(t => t.listed_in.includes(genre));
            }

            // Era match
            if (era === '2015') {
                candidates = candidates.filter(t => t.release_year >= 2015);
            } else if (era === '2000') {
                candidates = candidates.filter(t => t.release_year >= 2000 && t.release_year < 2015);
            } else if (era === '1900') {
                candidates = candidates.filter(t => t.release_year < 2000);
            }

            // Maturity match
            if (ratingOpt !== 'all') {
                if (ratingOpt === 'TV-MA') {
                    candidates = candidates.filter(t => ['TV-MA', 'R', 'NC-17'].includes(t.rating.toUpperCase()));
                } else if (ratingOpt === 'PG-13') {
                    candidates = candidates.filter(t => ['PG-13', 'TV-14', 'TV-PG'].includes(t.rating.toUpperCase()));
                } else if (ratingOpt === 'G') {
                    candidates = candidates.filter(t => ['G', 'PG', 'TV-G', 'TV-Y', 'TV-Y7'].includes(t.rating.toUpperCase()));
                }
            }

            const outputDiv = document.getElementById('recOutput');
            
            if(candidates.length === 0) {
                // If strictly no matched filters, grab any random title of correct Type
                candidates = allTitles.filter(t => t.type === recType);
            }

            // Draw random record
            const winner = candidates[Math.floor(Math.random() * candidates.length)];
            
            if (winner) {
                outputDiv.classList.remove('hidden');

                // Update cards
                const bType = document.getElementById('recOutputBadgeType');
                bType.innerText = winner.type;
                if(winner.type === 'Movie') {
                    bType.className = "text-[10px] font-bold bg-neonGreen/10 text-neonGreen border border-neonGreen/30 px-2 py-0.5 rounded uppercase";
                } else {
                    bType.className = "text-[10px] font-bold bg-lightBlue/10 text-lightBlue border border-lightBlue/30 px-2 py-0.5 rounded uppercase";
                }

                document.getElementById('recOutputBadgeYear').innerText = winner.release_year;
                document.getElementById('recOutputBadgeRating').innerText = winner.rating || 'NR';
                document.getElementById('recOutputBadgeDuration').innerText = winner.duration;
                document.getElementById('recOutputTitle').innerText = winner.title;
                document.getElementById('recOutputDesc').innerText = `"${winner.description}"`;
                document.getElementById('recOutputDirector').innerText = winner.director || 'N/A';
                document.getElementById('recOutputCast').innerText = winner.cast || 'N/A';
                document.getElementById('recOutputCategory').innerText = winner.listed_in;

                // Scroll recommendation output smoothly into view
                setTimeout(() => {
                    outputDiv.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
                }, 100);
            }
        }


