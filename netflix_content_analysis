<!DOCTYPE html>
<html lang="en" class="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Netflix Content Analysis Dashboard</title>
    <!-- Tailwind CSS CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Chart.js CDN -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <!-- Lucide Icons CDN -->
    <script src="https://unpkg.com/lucide@latest"></script>
    <!-- PapaParse CDN for CSV parsing -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/PapaParse/5.3.2/papaparse.min.js"></script>

    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        netflixBlack: '#0a0a0c',
                        netflixDarkGray: '#121216',
                        netflixCard: '#18181f',
                        neonGreen: '#39FF14',
                        lightBlue: '#38bdf8',
                        neonBlue: '#00F0FF',
                        cyberGray: '#24252d'
                    },
                    boxShadow: {
                        'neon-green': '0 0 15px rgba(57, 255, 20, 0.4)',
                        'neon-blue': '0 0 15px rgba(56, 189, 248, 0.4)',
                        'neon-mixed': '0 0 20px rgba(56, 189, 248, 0.25), 0 0 20px rgba(57, 255, 20, 0.25)',
                    }
                }
            }
        }
    </script>
    <style>
        /* Custom scrollbars */
        ::-webkit-scrollbar {
            width: 6px;
            height: 6px;
        }
        ::-webkit-scrollbar-track {
            background: #0a0a0c;
        }
        ::-webkit-scrollbar-thumb {
            background: #38bdf8;
            border-radius: 3px;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: #39FF14;
        }
        .glow-text-green {
            text-shadow: 0 0 10px rgba(57, 255, 20, 0.6);
        }
        .glow-text-blue {
            text-shadow: 0 0 10px rgba(56, 189, 248, 0.6);
        }
        .neon-border-green {
            border-color: rgba(57, 255, 20, 0.3);
            box-shadow: 0 0 10px rgba(57, 255, 20, 0.1);
        }
        .neon-border-green:focus {
            border-color: #39FF14;
            box-shadow: 0 0 15px rgba(57, 255, 20, 0.4);
            outline: none;
        }
    </style>
</head>
<body class="bg-netflixBlack text-white font-sans min-h-screen selection:bg-neonGreen selection:text-black">

    <!-- Header / Nav -->
    <header class="border-b border-lightBlue/20 bg-netflixDarkGray/95 sticky top-0 z-50 backdrop-blur-md px-6 py-4">
        <div class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-center gap-4">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-lg bg-netflixBlack border border-neonGreen flex items-center justify-center shadow-neon-green">
                    <span class="text-neonGreen font-bold text-xl tracking-wider">N</span>
                </div>
                <div>
                    <h1 class="text-2xl font-black tracking-tight flex items-center gap-2">
                        NETFLIX <span class="text-neonGreen glow-text-green">ANALYTICS</span>
                    </h1>
                    <p class="text-xs text-lightBlue uppercase tracking-widest font-semibold">Content Intelligence Dashboard</p>
                </div>
            </div>
            
            <div class="flex items-center gap-4">
                <div class="flex items-center gap-2 px-3 py-1.5 rounded-full bg-cyberGray border border-lightBlue/30 text-xs text-lightBlue">
                    <span class="w-2.5 h-2.5 rounded-full bg-neonGreen animate-ping"></span>
                    <span>Live Processing Engine</span>
                </div>
                <!-- Mini help banner -->
                <button onclick="toggleModal('infoModal')" class="p-2 rounded-lg bg-cyberGray hover:bg-lightBlue hover:text-black transition-all border border-lightBlue/20">
                    <i data-lucide="help-circle" class="w-5 h-5"></i>
                </button>
            </div>
        </div>
    </header>

    <main class="max-w-7xl mx-auto p-4 md:p-6 space-y-8">
        
        <!-- INITIAL LOADING OR CORRUPTED FILE STATE -->
        <div id="loadingState" class="flex flex-col items-center justify-center py-20 bg-netflixCard rounded-2xl border border-lightBlue/20 shadow-neon-mixed">
            <div class="relative w-24 h-24 mb-6">
                <div class="absolute inset-0 rounded-full border-4 border-lightBlue/20 border-t-neonGreen animate-spin"></div>
                <div class="absolute inset-2 rounded-full border-4 border-neonGreen/20 border-b-lightBlue animate-spin [animation-direction:reverse]"></div>
            </div>
            <h3 class="text-xl font-bold tracking-wider mb-2 text-white">PARSING NETFLIX METRICS...</h3>
            <p class="text-gray-400 text-sm max-w-md text-center px-4" id="loadingProgress">Initializing local server datasets, generating content index structures, and computing stats coefficients.</p>
        </div>

        <!-- MAIN DASHBOARD (HIDDEN UNTIL LOADED) -->
        <div id="dashboardContent" class="hidden space-y-8 animate-fade-in">
            
            <!-- CONTROLS & FILTERS HEADER -->
            <section class="bg-netflixDarkGray border border-lightBlue/20 rounded-2xl p-6 shadow-md">
                <div class="flex flex-col gap-4">
                    <div class="flex items-center justify-between">
                        <h2 class="text-lg font-bold flex items-center gap-2 text-lightBlue">
                            <i data-lucide="sliders-horizontal" class="w-5 h-5"></i> REAL-TIME COHORT FILTERING
                        </h2>
                        <button onclick="resetFilters()" class="text-xs font-semibold text-neonGreen hover:text-white transition-colors bg-cyberGray px-3 py-1.5 rounded border border-neonGreen/20 flex items-center gap-1.5">
                            <i data-lucide="rotate-ccw" class="w-3.5 h-3.5"></i> Clear All Filters
                        </button>
                    </div>
                    
                    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-4">
                        <!-- Search Title/Cast -->
                        <div class="col-span-1 sm:col-span-2 relative">
                            <label class="block text-xs uppercase tracking-wider text-gray-400 font-bold mb-1.5">Search Title, Cast, Director</label>
                            <div class="relative">
                                <i data-lucide="search" class="absolute left-3.5 top-3 w-4 h-4 text-gray-400"></i>
                                <input type="text" id="filterSearch" placeholder="Type a term (e.g., Peele, Thrillers...)" oninput="debouncedFilter()" class="w-full bg-netflixBlack rounded-lg pl-10 pr-4 py-2 border border-lightBlue/30 text-white placeholder-gray-500 focus:border-neonGreen focus:ring-1 focus:ring-neonGreen transition-all text-sm">
                            </div>
                        </div>

                        <!-- Type -->
                        <div>
                            <label class="block text-xs uppercase tracking-wider text-gray-400 font-bold mb-1.5">Media Type</label>
                            <select id="filterType" onchange="applyFilters()" class="w-full bg-netflixBlack rounded-lg px-3 py-2 border border-lightBlue/30 text-white focus:border-neonGreen transition-all text-sm">
                                <option value="all">📺 All Media Types</option>
                                <option value="Movie">🎬 Movies Only</option>
                                <option value="TV Show">🍿 TV Shows Only</option>
                            </select>
                        </div>

                        <!-- Release Year -->
                        <div>
                            <label class="block text-xs uppercase tracking-wider text-gray-400 font-bold mb-1.5">Release Era / Year</label>
                            <select id="filterYear" onchange="applyFilters()" class="w-full bg-netflixBlack rounded-lg px-3 py-2 border border-lightBlue/30 text-white focus:border-neonGreen transition-all text-sm">
                                <option value="all">🕒 All Eras</option>
                                <option value="recent">🌟 New Releases (2018-2021)</option>
                                <option value="2010s">📅 2010s Epoch</option>
                                <option value="2000s">📼 2000s Epoch</option>
                                <option value="90s">📼 90s Vintage</option>
                                <option value="classic">💾 Retro Classics (<1990)</option>
                            </select>
                        </div>

                        <!-- Rating selection -->
                        <div>
                            <label class="block text-xs uppercase tracking-wider text-gray-400 font-bold mb-1.5">Age Rating Group</label>
                            <select id="filterRating" onchange="applyFilters()" class="w-full bg-netflixBlack rounded-lg px-3 py-2 border border-lightBlue/30 text-white focus:border-neonGreen transition-all text-sm">
                                <option value="all">🔞 All Ratings</option>
                                <option value="mature">🔴 Adults Only (R, TV-MA)</option>
                                <option value="teens">🟡 Teens/Older (PG-13, TV-14)</option>
                                <option value="kids">🟢 Family Friendly (G, PG, TV-G, TV-Y)</option>
                            </select>
                        </div>
                    </div>

                    <!-- Meta summary badge list -->
                    <div class="flex flex-wrap items-center gap-2 pt-2 border-t border-lightBlue/10 text-xs text-gray-400">
                        <span>Active cohort scope:</span>
                        <span id="cohortCountBadge" class="bg-neonGreen/10 border border-neonGreen/30 text-neonGreen px-2.5 py-0.5 rounded-full font-mono">0 matching titles</span>
                        <span id="activeFiltersSummary" class="text-lightBlue"></span>
                    </div>
                </div>
            </section>

            <!-- METRIC KPI STATS -->
            <section class="grid grid-cols-2 lg:grid-cols-4 gap-4">
                <!-- Total Titles -->
                <div class="bg-netflixCard border border-lightBlue/20 rounded-2xl p-5 hover:scale-[1.02] transition-all duration-300 relative overflow-hidden group">
                    <div class="absolute -right-4 -bottom-4 opacity-5 group-hover:opacity-10 transition-opacity">
                        <i data-lucide="layers" class="w-32 h-32 text-lightBlue"></i>
                    </div>
                    <div class="flex justify-between items-start">
                        <p class="text-xs font-bold text-gray-400 uppercase tracking-widest">Total Catalogue Size</p>
                        <span class="p-1 rounded bg-lightBlue/10 text-lightBlue"><i data-lucide="layers" class="w-4 h-4"></i></span>
                    </div>
                    <p class="text-3xl md:text-4xl font-black mt-2 tracking-tight text-white font-mono" id="statTotal">0</p>
                    <p class="text-[10px] text-lightBlue mt-1 flex items-center gap-1">
                        <i data-lucide="trending-up" class="w-3 h-3 text-neonGreen"></i> All indexed movies & shows
                    </p>
                </div>

                <!-- Movies -->
                <div class="bg-netflixCard border border-lightBlue/20 rounded-2xl p-5 hover:scale-[1.02] transition-all duration-300 relative overflow-hidden group">
                    <div class="absolute -right-4 -bottom-4 opacity-5 group-hover:opacity-10 transition-opacity">
                        <i data-lucide="film" class="w-32 h-32 text-neonGreen"></i>
                    </div>
                    <div class="flex justify-between items-start">
                        <p class="text-xs font-bold text-gray-400 uppercase tracking-widest">Feature Movies</p>
                        <span class="p-1 rounded bg-neonGreen/10 text-neonGreen"><i data-lucide="film" class="w-4 h-4"></i></span>
                    </div>
                    <p class="text-3xl md:text-4xl font-black mt-2 tracking-tight text-white font-mono" id="statMovies">0</p>
                    <p class="text-[10px] text-gray-400 mt-1" id="statMoviePercent">0% of aggregate volume</p>
                </div>

                <!-- TV Shows -->
                <div class="bg-netflixCard border border-lightBlue/20 rounded-2xl p-5 hover:scale-[1.02] transition-all duration-300 relative overflow-hidden group">
                    <div class="absolute -right-4 -bottom-4 opacity-5 group-hover:opacity-10 transition-opacity">
                        <i data-lucide="tv" class="w-32 h-32 text-lightBlue"></i>
                    </div>
                    <div class="flex justify-between items-start">
                        <p class="text-xs font-bold text-gray-400 uppercase tracking-widest">TV Series Seasons</p>
                        <span class="p-1 rounded bg-lightBlue/10 text-lightBlue"><i data-lucide="tv" class="w-4 h-4"></i></span>
                    </div>
                    <p class="text-3xl md:text-4xl font-black mt-2 tracking-tight text-white font-mono" id="statTVShows">0</p>
                    <p class="text-[10px] text-gray-400 mt-1" id="statTVPercent">0% of aggregate volume</p>
                </div>

                <!-- Production Capital -->
                <div class="bg-netflixCard border border-lightBlue/20 rounded-2xl p-5 hover:scale-[1.02] transition-all duration-300 relative overflow-hidden group">
                    <div class="absolute -right-4 -bottom-4 opacity-5 group-hover:opacity-10 transition-opacity">
                        <i data-lucide="globe" class="w-32 h-32 text-neonGreen"></i>
                    </div>
                    <div class="flex justify-between items-start">
                        <p class="text-xs font-bold text-gray-400 uppercase tracking-widest">Primary Origin Hub</p>
                        <span class="p-1 rounded bg-neonGreen/10 text-neonGreen"><i data-lucide="globe" class="w-4 h-4"></i></span>
                    </div>
                    <p class="text-xl md:text-2xl font-black mt-3 truncate tracking-tight text-white uppercase" id="statTopCountry">N/A</p>
                    <p class="text-[10px] text-neonGreen mt-2" id="statCountryCount">0 titles originated here</p>
                </div>
            </section>

            <!-- MAIN DATA VISUALIZATIONS GRID -->
            <section class="grid grid-cols-1 lg:grid-cols-3 gap-6">
                <!-- Timeline/Content Curve (Line Chart) - span 2 -->
                <div class="lg:col-span-2 bg-netflixCard border border-lightBlue/20 rounded-2xl p-6 flex flex-col justify-between">
                    <div>
                        <div class="flex justify-between items-center mb-1">
                            <h3 class="text-md font-bold text-white uppercase tracking-wider flex items-center gap-2">
                                <i data-lucide="trending-up" class="w-4.5 h-4.5 text-neonGreen"></i> Historical Content Ingestion Curve
                            </h3>
                            <span class="text-[10px] font-mono text-neonGreen bg-neonGreen/10 px-2 py-0.5 rounded border border-neonGreen/30">Temporal distribution</span>
                        </div>
                        <p class="text-xs text-gray-400 mb-4">Chronology of Netflix content production volumes categorized by release years.</p>
                    </div>
                    <div class="h-72 w-full relative">
                        <canvas id="historicalChart"></canvas>
                    </div>
                </div>

                <!-- Movie vs TV Show Ratio (Doughnut) - span 1 -->
                <div class="bg-netflixCard border border-lightBlue/20 rounded-2xl p-6 flex flex-col justify-between">
                    <div>
                        <div class="flex justify-between items-center mb-1">
                            <h3 class="text-md font-bold text-white uppercase tracking-wider flex items-center gap-2">
                                <i data-lucide="pie-chart" class="w-4.5 h-4.5 text-lightBlue"></i> Format Segment Ratio
                            </h3>
                            <span class="text-[10px] font-mono text-lightBlue bg-lightBlue/10 px-2 py-0.5 rounded border border-lightBlue/30">Type split</span>
                        </div>
                        <p class="text-xs text-gray-400 mb-4">Comparing feature-length cinematography against multi-episode seasons.</p>
                    </div>
                    <div class="h-56 w-full relative flex items-center justify-center">
                        <canvas id="typeRatioChart"></canvas>
                    </div>
                    <div class="mt-4 pt-4 border-t border-lightBlue/10 flex justify-around text-center text-xs">
                        <div>
                            <span class="inline-block w-2.5 h-2.5 rounded-full bg-neonGreen mr-1.5"></span>
                            <span class="text-gray-400">Movies</span>
                            <div class="font-bold text-white font-mono text-sm" id="donutMovieVal">0</div>
                        </div>
                        <div>
                            <span class="inline-block w-2.5 h-2.5 rounded-full bg-lightBlue mr-1.5"></span>
                            <span class="text-gray-400">TV Shows</span>
                            <div class="font-bold text-white font-mono text-sm" id="donutTVVal">0</div>
                        </div>
                    </div>
                </div>

                <!-- Top 10 Genres (Horizontal Bar) - span 2 -->
                <div class="lg:col-span-2 bg-netflixCard border border-lightBlue/20 rounded-2xl p-6 flex flex-col justify-between">
                    <div>
                        <div class="flex justify-between items-center mb-1">
                            <h3 class="text-md font-bold text-white uppercase tracking-wider flex items-center gap-2">
                                <i data-lucide="bar-chart-2" class="w-4.5 h-4.5 text-neonGreen"></i> Leading Entertainment Genres
                            </h3>
                            <span class="text-[10px] font-mono text-neonGreen bg-neonGreen/10 px-2 py-0.5 rounded border border-neonGreen/30">Top 10 Genres</span>
                        </div>
                        <p class="text-xs text-gray-400 mb-4">Volume density across top 10 unique content tags (non-aggregated lists).</p>
                    </div>
                    <div class="h-80 w-full relative">
                        <canvas id="genreChart"></canvas>
                    </div>
                </div>

                <!-- Rating Breakdowns (Horizontal / Polar) - span 1 -->
                <div class="bg-netflixCard border border-lightBlue/20 rounded-2xl p-6 flex flex-col justify-between">
                    <div>
                        <div class="flex justify-between items-center mb-1">
                            <h3 class="text-md font-bold text-white uppercase tracking-wider flex items-center gap-2">
                                <i data-lucide="shield-alert" class="w-4.5 h-4.5 text-lightBlue"></i> Content Rating Profile
                            </h3>
                            <span class="text-[10px] font-mono text-lightBlue bg-lightBlue/10 px-2 py-0.5 rounded border border-lightBlue/30">Maturity spectrum</span>
                        </div>
                        <p class="text-xs text-gray-400 mb-4">Audience restriction breakdown to determine content core age targeting.</p>
                    </div>
                    <div class="h-72 w-full relative flex items-center justify-center">
                        <canvas id="ratingChart"></canvas>
                    </div>
                </div>
            </section>

            <!-- INTELLIGENT RECOMMENDATION ENGINE (INTERACTIVE FEATURE) -->
            <section class="bg-netflixCard border border-lightBlue/20 rounded-2xl p-6 shadow-neon-mixed relative overflow-hidden">
                <div class="absolute top-0 right-0 w-64 h-64 bg-neonGreen/5 rounded-full blur-3xl pointer-events-none"></div>
                <div class="absolute bottom-0 left-0 w-64 h-64 bg-lightBlue/5 rounded-full blur-3xl pointer-events-none"></div>

                <div class="relative z-10">
                    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-6">
                        <div>
                            <span class="text-[10px] font-bold tracking-widest text-neonGreen bg-neonGreen/10 border border-neonGreen/30 px-2.5 py-1 rounded-full uppercase">AI Recommendation Core</span>
                            <h2 class="text-xl font-extrabold mt-2 uppercase tracking-wide flex items-center gap-2">
                                <i data-lucide="sparkles" class="w-5.5 h-5.5 text-neonGreen animate-pulse"></i> Custom Content Generator
                            </h2>
                            <p class="text-xs text-gray-400">Specify features below to simulate an optimized streaming suggestion based on your library.</p>
                        </div>
                        
                        <div class="flex items-center gap-2 bg-netflixBlack p-1 rounded-lg border border-lightBlue/20">
                            <button onclick="setRecType('Movie')" id="recBtnMovie" class="px-3 py-1.5 rounded text-xs font-bold transition-all text-neonGreen bg-neonGreen/10 border border-neonGreen/20">Movies</button>
                            <button onclick="setRecType('TV Show')" id="recBtnTV" class="px-3 py-1.5 rounded text-xs font-bold text-gray-400 hover:text-white transition-all">TV Shows</button>
                        </div>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-4 gap-4 items-end bg-netflixDarkGray/80 p-5 rounded-xl border border-lightBlue/10">
                        <div>
                            <label class="block text-xs uppercase tracking-wider text-gray-400 font-bold mb-1.5">Select Main Genre</label>
                            <select id="recGenreSelect" class="w-full bg-netflixBlack rounded-lg px-3 py-2 border border-lightBlue/30 text-white text-sm focus:border-neonGreen"></select>
                        </div>
                        <div>
                            <label class="block text-xs uppercase tracking-wider text-gray-400 font-bold mb-1.5">Select Era</label>
                            <select id="recYearSelect" class="w-full bg-netflixBlack rounded-lg px-3 py-2 border border-lightBlue/30 text-white text-sm focus:border-neonGreen">
                                <option value="all">Any Era</option>
                                <option value="2015">Modern (2015+)</option>
                                <option value="2000">Y2K Era (2000-2014)</option>
                                <option value="1900">Vintage (Before 2000)</option>
                            </select>
                        </div>
                        <div>
                            <label class="block text-xs uppercase tracking-wider text-gray-400 font-bold mb-1.5">Maturity Rating</label>
                            <select id="recRatingSelect" class="w-full bg-netflixBlack rounded-lg px-3 py-2 border border-lightBlue/30 text-white text-sm focus:border-neonGreen">
                                <option value="all">Any Rating</option>
                                <option value="TV-MA">Mature (TV-MA, R)</option>
                                <option value="PG-13">Teens (TV-14, PG-13)</option>
                                <option value="G">Kids/Family (TV-G, G, PG)</option>
                            </select>
                        </div>
                        <button onclick="generateRecommendation()" class="bg-neonGreen text-black font-extrabold px-6 py-2.5 rounded-lg hover:shadow-neon-green active:scale-95 transition-all text-sm uppercase flex items-center justify-center gap-2">
                            <i data-lucide="play" class="w-4 h-4 fill-black"></i> Run Generator
                        </button>
                    </div>

                    <!-- RECOMMENDATION OUTPUT CONTAINER -->
                    <div id="recOutput" class="mt-6 hidden animate-fade-in">
                        <div class="bg-netflixBlack border border-neonGreen/40 rounded-xl p-5 md:p-6 flex flex-col md:flex-row gap-6 relative overflow-hidden">
                            <!-- Neon highlight strip -->
                            <div class="absolute left-0 top-0 bottom-0 w-1.5 bg-neonGreen"></div>
                            
                            <!-- Main movie specs -->
                            <div class="flex-1 space-y-3">
                                <div class="flex flex-wrap items-center gap-2">
                                    <span id="recOutputBadgeType" class="text-[10px] font-bold bg-lightBlue/10 text-lightBlue border border-lightBlue/30 px-2 py-0.5 rounded uppercase">Movie</span>
                                    <span id="recOutputBadgeYear" class="text-[10px] font-mono font-bold bg-cyberGray text-white border border-gray-700 px-2 py-0.5 rounded">2019</span>
                                    <span id="recOutputBadgeRating" class="text-[10px] font-bold bg-neonGreen/10 text-neonGreen border border-neonGreen/30 px-2 py-0.5 rounded">TV-MA</span>
                                    <span id="recOutputBadgeDuration" class="text-[10px] font-mono font-bold bg-cyberGray text-gray-300 px-2 py-0.5 rounded">110 min</span>
                                </div>
                                
                                <h3 id="recOutputTitle" class="text-2xl font-black text-white uppercase tracking-tight">TITLE OF THE CONTENT</h3>
                                
                                <p id="recOutputDesc" class="text-sm text-gray-300 leading-relaxed italic">"An interesting description of this specific production."</p>
                                
                                <div class="grid grid-cols-1 md:grid-cols-2 gap-4 text-xs pt-2 border-t border-gray-800">
                                    <div>
                                        <span class="text-gray-500 font-bold block uppercase tracking-wider mb-0.5">Directed By</span>
                                        <span id="recOutputDirector" class="text-lightBlue font-semibold">Director Name</span>
                                    </div>
                                    <div>
                                        <span class="text-gray-500 font-bold block uppercase tracking-wider mb-0.5">Top Cast</span>
                                        <span id="recOutputCast" class="text-white">Cast Name 1, Cast Name 2</span>
                                    </div>
                                    <div class="md:col-span-2">
                                        <span class="text-gray-500 font-bold block uppercase tracking-wider mb-0.5">Listed Under Categories</span>
                                        <span id="recOutputCategory" class="text-neonGreen">Action, Sci-Fi</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <!-- DATA TABLE EXPLORER -->
            <section class="bg-netflixCard border border-lightBlue/20 rounded-2xl p-6 shadow-md">
                <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-4">
                    <div>
                        <h3 class="text-md font-bold text-white uppercase tracking-wider flex items-center gap-2">
                            <i data-lucide="database" class="w-5 h-5 text-lightBlue"></i> Comprehensive Catalogue Table
                        </h3>
                        <p class="text-xs text-gray-400">Paginated view over custom-filtered results. Click column headers to inspect content detail records.</p>
                    </div>
                    <div class="flex items-center gap-2">
                        <span class="text-xs text-gray-400">Rows per page:</span>
                        <select id="pageSizeSelect" onchange="changePageSize()" class="bg-netflixBlack text-xs rounded border border-lightBlue/30 px-2 py-1 focus:border-neonGreen">
                            <option value="10">10</option>
                            <option value="25" selected>25</option>
